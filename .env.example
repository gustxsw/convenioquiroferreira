# Database Configuration
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# JWT Secret
JWT_SECRET=change-me

# MercadoPago Configuration
# IMPORTANTE: Use credenciais de TESTE para desenvolvimento
# Para produção, substitua pelas credenciais reais
MP_ACCESS_TOKEN=your-mercadopago-access-token
MP_PUBLIC_KEY=your-mercadopago-public-key

# MercadoPago Sandbox Mode
# Defina como 'true' para usar sandbox, 'false' para produção
MP_SANDBOX_MODE=true

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Geração de PDF via Python (reportlab) — chamado diretamente, sem Docker nem servidor HTTP.
# Instale as dependências uma vez: pip install -r scripts/requirements.txt
# Opcional: caminho completo para o executável Python se não estiver no PATH
# DOCUMENT_SERVICE_PYTHON=python
# DOCUMENT_SERVICE_TIMEOUT_MS=60000

# WhatsApp Cloud API (Meta) — envio direto de documento por link público
# WHATSAPP_CLOUD_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Secretária Virtual via WhatsApp (Meta Cloud API) — reusa WHATSAPP_CLOUD_TOKEN/PHONE_NUMBER_ID acima
# Token de verificação do webhook (você define; o mesmo valor é configurado no painel da Meta)
# WHATSAPP_VERIFY_TOKEN=
# JSON mapeando número (phone_number_id ou número E.164) -> professionalId. Ex.: {"5564999990001": 1}
# WHATSAPP_NUMBERS=
# Número humano (apenas dígitos) para fallback do fluxo CONVENIO quando a IA não responde
# WHATSAPP_HUMAN_FALLBACK=
# Token fixo que protege GET /webhook/whatsapp/metrics
# WHATSAPP_METRICS_TOKEN=
# Chave da API Anthropic (fluxo CONVENIO usa claude-haiku-4-5-20251001)
# ANTHROPIC_API_KEY=
# Modo IA da secretária: a IA conduz TODA a conversa via ferramentas (não só o convênio).
#   on            -> todos os números
#   prof:2,5      -> apenas os profissionais de id 2 e 5 (recomendado para testar)
#   off / ausente -> mantém o bot por palavra-chave
# WHATSAPP_AI_MODE=off
# Cotação USD→BRL usada para estimar o custo da IA em reais nos relatórios.
# Atualizar periodicamente — cotação atual em https://www.bcb.gov.br
# USD_BRL_RATE=5.20

# Integração Google Agenda + Google Meet (bidirecional)
# OAuth Client (Web) do Google Cloud com a Calendar API habilitada.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Redirect URI registrado no Console (dev: http://localhost:3001/api/google/callback;
# prod: https://www.cartaoquiroferreira.com.br/api/google/callback)
# GOOGLE_REDIRECT_URI=
# Base pública HTTPS que recebe as notificações push (events.watch). O domínio precisa
# estar verificado no Google. Ex.: https://www.cartaoquiroferreira.com.br
# GOOGLE_WEBHOOK_URL=
# Opcional: chave para criptografar o refresh token at-rest (hardening futuro)
# GOOGLE_TOKEN_ENC_KEY=

# Server Configuration
PORT=3001
NODE_ENV=production

# URL pública do site (link no e-mail de redefinição de senha). Opcional.
# FRONTEND_URL=https://www.cartaoquiroferreira.com.br

# Build do Vite: URL da API se o front for servido de outro domínio (obrigatório nesse caso).
# Ex.: VITE_API_URL=https://www.cartaoquiroferreira.com.br
# VITE_API_URL=

# WhatsApp do responsável pelo convênio (apenas dígitos, ex. DDI+DDD+número). Usado nos CTAs de profissionais "apenas agenda".
# Opcional: se vazio, o front usa o número padrão da equipe (fallback no código).
# VITE_WHATSAPP_CONVENIO_OWNER=5564981210313

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password
SMTP_FROM=your-email@gmail.com