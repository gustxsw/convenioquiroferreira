{% extends "base.html.j2" %}
{% block body %}
<div class="document-title">Receituário Médico</div>
<div class="patient-info">
  <strong>Paciente:</strong> {{ patient_name | e }}<br />
  {% if patient_cpf %}<strong>CPF:</strong> {{ patient_cpf | e }}<br />{% endif %}
  <strong>Data de Emissão:</strong> {{ current_date | e }}
</div>
<div class="prescription-box">
  <div class="prescription-content">{{ prescription | e }}</div>
</div>
<div class="signature-area">
  <div class="electronic-validation">
    <p class="ev-label">Documento validado eletronicamente</p>
    <strong>{{ professional_name | e }}</strong><br />
    {% if professional_specialty %}{{ professional_specialty | e }}<br />{% endif %}
    {% if crm %}{{ crm | e }}<br />{% endif %}
    {{ validation_datetime | e }}
  </div>
</div>
{% endblock %}
