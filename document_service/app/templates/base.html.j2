<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>{{ doc_title | e }}</title>
  <style>
    @page { size: A4; margin: 15mm; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: "Times New Roman", Times, serif;
      font-size: 14px;
      line-height: 1.6;
      color: #000;
      background: #fff;
      padding: 20px;
    }
    .document-title {
      font-size: 20px;
      font-weight: bold;
      text-transform: uppercase;
      text-align: center;
      margin: 30px 0;
    }
    .patient-info {
      background: #f9f9f9;
      padding: 15px;
      margin: 20px 0;
      border-left: 4px solid #333;
      border-radius: 4px;
    }
    .content-section { margin: 20px 0; padding: 15px; }
    .section-title {
      font-size: 16px;
      font-weight: bold;
      margin-bottom: 10px;
      border-bottom: 1px solid #eee;
      padding-bottom: 5px;
    }
    .prescription-box {
      border: 2px solid #333;
      padding: 20px;
      margin: 20px 0;
      min-height: 120px;
    }
    .prescription-content {
      font-size: 16px;
      line-height: 2;
      white-space: pre-line;
    }
    .clinic-logo-header {
      text-align: center;
      margin-bottom: 18px;
      padding-bottom: 14px;
      border-bottom: 1px solid #ddd;
    }
    .clinic-logo-header img {
      max-height: 80px;
      max-width: 260px;
      object-fit: contain;
    }
    .signature-area { margin-top: 48px; text-align: center; }
    .dual-signature {
      margin-top: 48px;
      display: flex;
      justify-content: space-between;
    }
    .signature-box { text-align: center; width: 45%; }
    .signature-line {
      border-top: 1px solid #000;
      width: 80%;
      margin: 40px auto 10px;
    }
    .electronic-validation {
      display: inline-block;
      border: 1px solid #aaa;
      border-radius: 6px;
      padding: 10px 18px;
      text-align: center;
      font-size: 12px;
      line-height: 1.8;
      margin: 16px auto 10px;
      background: #f7f7f7;
    }
    .ev-label {
      font-size: 10px;
      color: #555;
      letter-spacing: 0.4px;
      text-transform: uppercase;
      font-style: italic;
      margin-bottom: 4px;
    }
    p { margin: 10px 0; text-align: justify; }
    ul { margin: 10px 0; padding-left: 20px; }
    li { margin: 5px 0; }
  </style>
</head>
<body>
{% if logo_url %}
<div class="clinic-logo-header">
  <img src="{{ logo_url | e }}" alt="Logo da Clínica" />
</div>
{% endif %}
{% block body %}{% endblock %}
</body>
</html>
